---
import Layout from "@/layouts/Layout.astro";
import BaseSkillsManager from "@/components/BaseSkillsManager.tsx";
---

<Layout title="10xwork-find">
  <main class="mx-auto flex min-h-screen max-w-3xl flex-col gap-6 px-6 py-12">
    <header class="flex flex-col gap-1">
      <h1 class="text-2xl font-semibold tracking-tight">10xwork-find</h1>
      <p class="text-sm text-gray-500">Wklej wymagania z oferty pracy i otrzymaj sekcję umiejętności gotową do CV.</p>
    </header>

    <!-- Tool surface. Base-skills management (S-01) mounts here; posting matching (S-02) follows. -->
    <section id="app-root" aria-label="Narzędzie">
      <BaseSkillsManager client:only="react" />
    </section>
  </main>
</Layout>
