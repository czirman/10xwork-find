---
import Layout from "@/layouts/Layout.astro";

// Purely presentational. The middleware owns all gate redirects (including
// bouncing an already-unlocked visitor home), so this page only renders the
// form and reflects the ?error=1 flag set by /api/unlock on a failed attempt.
const hasError = Astro.url.searchParams.get("error") === "1";
---

<Layout title="Odblokuj — 10xwork-find">
  <main class="mx-auto flex min-h-screen max-w-sm flex-col justify-center gap-6 px-6 py-12">
    <header class="flex flex-col gap-1">
      <h1 class="text-2xl font-semibold tracking-tight">10xwork-find</h1>
      <p class="text-sm text-gray-500">Podaj hasło dostępu, aby otworzyć narzędzie.</p>
    </header>

    <form method="POST" action="/api/unlock" class="flex flex-col gap-3">
      <label class="flex flex-col gap-1 text-sm font-medium">
        Hasło dostępu
        <input
          type="password"
          name="passphrase"
          required
          autocomplete="current-password"
          class="rounded-md border border-gray-300 px-3 py-2 text-base font-normal focus:border-gray-900 focus:outline-none"
        />
      </label>

      {
        hasError && (
          <p role="alert" class="text-sm text-red-600">
            Nieprawidłowe hasło. Spróbuj ponownie.
          </p>
        )
      }

      <button type="submit" class="rounded-md bg-gray-900 px-3 py-2 text-sm font-medium text-white hover:bg-gray-700">
        Odblokuj
      </button>
    </form>
  </main>
</Layout>
